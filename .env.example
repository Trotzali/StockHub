# .env.example — committed template. Copy to .env and fill in real values.
# .env is gitignored.

# ─── Supabase project ────────────────────────────────────────────
SUPABASE_URL=https://[your-project-ref].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Direct Postgres connection ──────────────────────────────────
# For migrations, batch loads, smoke tests (psycopg2 / supabase-py admin).
# Find these under Supabase project → Project Settings → Database.
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=

# ─── Data feed API keys (added in later WPs) ─────────────────────
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
